{
    "name":  "burstcode-local-alerts",
    "displayName":  "BurstCode Local Alerts Companion",
    "description":  "Local UI companion for BurstCode Remote SSH sound and taskbar attention alerts.",
    "version":  "0.1.117",
    "publisher":  "burstcode",
    "engines":  {
                    "vscode":  "^1.106.0"
                },
    "categories":  [
                       "Other"
                   ],
    "main":  "./dist/extension.js",
    "extensionKind":  [
                          "ui"
                      ],
    "activationEvents":  [
                             "onCommand:burstcode.alert.start",
                             "onCommand:burstcode.alert.stop",
                             "onCommand:burstcode.alert.notify"
                         ],
    "contributes":  {
                        "commands":  [
                                         {
                                             "command":  "burstcode.alert.start",
                                             "title":  "BurstCode Alerts: Start Local Alert"
                                         },
                                         {
                                             "command":  "burstcode.alert.stop",
                                             "title":  "BurstCode Alerts: Stop Local Alert"
                                         },
                                         {
                                             "command":  "burstcode.alert.notify",
                                             "title":  "BurstCode Alerts: Notify Locally"
                                         }
                                     ],
                        "menus":  {
                                      "commandPalette":  [
                                                             {
                                                                 "command":  "burstcode.alert.start",
                                                                 "when":  "false"
                                                             },
                                                             {
                                                                 "command":  "burstcode.alert.stop",
                                                                 "when":  "false"
                                                             },
                                                             {
                                                                 "command":  "burstcode.alert.notify",
                                                                 "when":  "false"
                                                             }
                                                         ]
                                  }
                    }
}
